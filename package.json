{
  "name": "@kapoost/abzu",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Abzu — AdCP buyer-side orchestrator",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "typecheck": "bun --bun tsc --noEmit",
    "test": "bun test",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "storyboard": "bun run storyboards/cli.ts"
  },
  "dependencies": {
    "@adcp/sdk": "9.7.0",
    "jose": "5.9.6",
    "postgres": "^3.4.9",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
